# Local dev — PostgreSQL 17 running on host port 5432
# (EDB installer). After running scripts/setup_db.sql:
DATABASE_URL=postgresql+asyncpg://kyros:kyros@localhost:5432/kyros

# If using docker-compose postgres instead (port 5433):
# DATABASE_URL=postgresql+asyncpg://kyros:kyros@localhost:5433/kyros

REDIS_URL=redis://localhost:6379/0
STORAGE_DIR=./storage
STORAGE_BACKEND=local
SIGNING_SECRET=change-me-in-production
LOG_LEVEL=INFO
ENV=development

# Admin panel — generate hash with: python -m app.admin.cli set-password
ADMIN_USERNAME=Niranjan@kyros
ADMIN_PASSWORD_HASH=$2b$12$koFaDwsLZiLQUebsA6OowuRPxkksiHeiSyZzE10bEX8cQbJiU2Woi
SENTRY_DASHBOARD_URL=https://sentry.io/organizations/your-org/projects/kyros-backend/
UPTIME_DASHBOARD_URL=https://uptime.betterstack.com/
ADMIN_SESSION_TIMEOUT_MINUTES=60
