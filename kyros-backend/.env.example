# Local dev — PostgreSQL 17 running on host port 5432
# (EDB installer). After running scripts/setup_db.sql:
DATABASE_URL=postgresql+asyncpg://kyros:kyros@localhost:5432/kyros

# If using docker-compose postgres instead (port 5433):
# DATABASE_URL=postgresql+asyncpg://kyros:kyros@localhost:5433/kyros

REDIS_URL=redis://localhost:6379/0
STORAGE_DIR=./storage
STORAGE_BACKEND=local
SIGNING_SECRET=change-me-in-production
LOG_LEVEL=INFO
ENV=development
